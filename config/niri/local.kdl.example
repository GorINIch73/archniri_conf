// Copy this file to ~/.config/niri/local.kdl for machine-specific settings.
// Use `niri msg outputs` to find the real connector name and current values.
// After editing, run:
//   niri msg action load-config-file
//   niri msg outputs
// Then verify that the active output reports the expected values.
//
// Example:
//
// output "DP-5" {
//     mode "3440x1440@164.999"
//     scale 1
//     transform "normal"
//     position x=0 y=0
// }
